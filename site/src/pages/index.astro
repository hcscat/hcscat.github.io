---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const coreStack = [
	'Java',
	'Spring',
	'MyBatis',
	'JavaScript',
	'JSP',
	'Nexacro',
	'exBuilder6',
	'SAP UI5/Fiori',
	'Oracle',
	'MSSQL',
	'Linux',
	'Shell Script',
];

const careerTimeline = [
	{
		period: '2025.10 ~ 현재',
		text: 'SAP UI5/Fiori, JavaScript, CSS, Git 기반 기업 솔루션 운영개발',
	},
	{
		period: '2024.12 ~ 2025.08',
		text: '공공기관 업무관리시스템 구축, exBuilder6 + Java/Spring/Oracle',
	},
	{
		period: '2022.02 ~ 2024.08',
		text: '대형 이커머스몰 운영개발, 주문/결제, PG 연동, 배송채널, Nexacro/JSP/Java/Spring/MSSQL',
	},
	{
		period: '2016.11 ~ 2021.08',
		text: '솔루션/웹/앱 QA, Linux/DB 환경 검증, 테스트케이스, 이슈 추적',
	},
];
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="wide">
			<section class="home-hero">
				<div>
					<p class="eyebrow">Java/Spring · Enterprise Web · QA-minded Engineering</p>
					<h1>황창식</h1>
					<p class="lead">
						품질 관점을 가진 Java/Spring 기반 업무 시스템 개발자입니다. QA/QC 경험을
						바탕으로 기존 시스템 분석, 변경 영향도 확인, 업무 화면과 백엔드 연결을 중요하게
						봅니다.
					</p>
					<ul class="summary-list">
						<li>Java, Spring, MyBatis 기반 업무 시스템 개발</li>
						<li>Nexacro, exBuilder6, SAP UI5/Fiori 기반 엔터프라이즈 UI 운영개발</li>
						<li>공공 시스템, 이커머스 운영개발, 백오피스/관리자 화면 경험</li>
						<li>QA/QC 기반 테스트, 이슈 추적, 예외 케이스 검토 관점</li>
					</ul>
				</div>

				<aside id="contact" class="panel quick-contact">
					<p class="eyebrow">Contact</p>
					<h2>연락 채널</h2>
					<ul class="contact-list">
						<li>
							<span>Email</span>
							<a href="mailto:hcs88cp@gmail.com">hcs88cp@gmail.com</a>
						</li>
						<li>
							<span>GitHub</span>
							<a href="https://github.com/hcscat" target="_blank" rel="noreferrer">github.com/hcscat</a>
						</li>
						<li>
							<span>LinkedIn</span>
							<a href="https://www.linkedin.com/in/changsikhwang/" target="_blank" rel="noreferrer">
								linkedin.com/in/changsikhwang
							</a>
						</li>
					</ul>
					<div class="quick-stack">
						<strong>Core Stack</strong>
						<p>Java / Spring / MyBatis / JavaScript / SAP UI5/Fiori / Oracle / MSSQL</p>
					</div>
				</aside>
			</section>

			<section class="section-grid two">
				<div class="panel">
					<p class="eyebrow">Career</p>
					<h2>이력 요약</h2>
					<div class="mini-timeline">
						{
							careerTimeline.map((item) => (
								<div>
									<strong>{item.period}</strong>
									<p>{item.text}</p>
								</div>
							))
						}
					</div>
				</div>
				<div class="panel">
					<p class="eyebrow">Core Stack</p>
					<h2>기술 스택</h2>
					<ul class="stack-list">
						{coreStack.map((item) => <li>{item}</li>)}
					</ul>
				</div>
			</section>

			<section class="panel">
				<p class="eyebrow">Positioning</p>
				<h2>업무 화면과 백엔드를 함께 보는 개발자</h2>
				<p>
					Nexacro, exBuilder6, JSP, SAP UI5/Fiori 등 엔터프라이즈 UI 환경과 Java,
					Spring, MyBatis, Oracle, MSSQL 기반 업무 로직을 함께 다룬 경험이 강점입니다.
					공개 포트폴리오에서는 고객사 내부 화면, 실제 데이터, 내부 URL을 제외하고 역할과
					기술 흐름만 정리합니다.
				</p>
			</section>

			<section class="note-box">
				<p class="eyebrow">Public Scope</p>
				<h2>공개 범위</h2>
				<p>
					이 사이트는 공개용 포트폴리오이므로 연락처, 상세 주소, 업무 시스템 화면, 고객사 내부
					정보는 제외하거나 비식별화합니다. 세부 이력서와 경력기술서는 입사지원 문서에서 별도로
					관리합니다.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
