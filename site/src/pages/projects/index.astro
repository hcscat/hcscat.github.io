---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION } from '../../consts';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title="Projects | HCS Portfolio" description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="wide">
			<section class="page-heading">
				<p class="eyebrow">Projects</p>
				<h1>대표 프로젝트</h1>
				<p class="lead">
					현재 진행 중인 기업 솔루션 운영개발을 먼저 배치하고, 이후 경력은 최근순으로
					정리했습니다.
				</p>
			</section>

			<section class="project-list">
				{
					projects.map((project) => (
						<a class="project-card" href={`/projects/${project.id}/`}>
							<span>{project.data.period}</span>
							<h2>{project.data.title}</h2>
							<p>{project.data.summary}</p>
							<div class="inline-meta">{project.data.role}</div>
							<ul>
								{project.data.highlights.map((highlight) => <li>{highlight}</li>)}
							</ul>
						</a>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>
